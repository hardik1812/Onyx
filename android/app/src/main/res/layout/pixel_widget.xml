<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pixel_widget_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:background="@drawable/pixel_widget_background"
    android:gravity="center_vertical"
    android:minHeight="80dp">

    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_edit"
        android:layout_marginLeft="20dp"
        android:layout_marginStart="20dp"
        android:tint="#80FFFFFF"/>

    <TextView
        android:id="@+id/widget_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="What's on your mind?"
        android:textColor="#40FFFFFF"
        android:textSize="20sp"
        android:paddingLeft="16dp"
        android:paddingStart="16dp"
        android:fontFamily="sans-serif"/>

    <ImageView
        android:id="@+id/widget_camera"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_camera"
        android:layout_marginRight="20dp"
        android:layout_marginEnd="20dp"
        android:tint="#80FFFFFF"/>

    <FrameLayout
        android:id="@+id/widget_add_btn"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginRight="8dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/widget_add_button_bg">
        
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_menu_add"
            android:tint="#121318" />
    </FrameLayout>
</LinearLayout>